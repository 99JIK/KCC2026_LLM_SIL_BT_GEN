<root BTCPP_format="4">
  <!-- Generic example: a smart thermostat. Not related to any SITL domain.
       Demonstrates a behavior repertoire with parallel independent subsystems
       running concurrently (sensing / control / scheduling / fault). -->
  <BehaviorTree ID="SmartThermostatRepertoire">
    <Parallel success_count="4" failure_count="1">

      <!-- Sensing subsystem -->
      <Sequence name="sensing_loop">
        <Action ID="ReadTemperatureSensor"/>
        <Action ID="ReadHumiditySensor"/>
        <Action ID="ReadOccupancySensor"/>
        <Action ID="UpdateBlackboard"/>
      </Sequence>

      <!-- Control subsystem -->
      <Fallback name="control_decision">
        <Sequence name="cooling_branch">
          <Condition ID="IsTooHot"/>
          <Action ID="StartCompressor"/>
          <Action ID="OpenDampers"/>
        </Sequence>
        <Sequence name="heating_branch">
          <Condition ID="IsTooCold"/>
          <Action ID="StartHeater"/>
          <Action ID="OpenDampers"/>
        </Sequence>
        <Sequence name="idle_branch">
          <Action ID="StopAllActuators"/>
        </Sequence>
      </Fallback>

      <!-- Scheduling subsystem -->
      <Fallback name="schedule_handler">
        <Sequence name="apply_schedule">
          <Condition ID="IsScheduledChangePending"/>
          <Action ID="ApplyScheduledSetpoint"/>
        </Sequence>
        <Sequence name="vacation_mode">
          <Condition ID="IsVacationModeActive"/>
          <Action ID="SetEcoSetpoint"/>
        </Sequence>
        <ForceSuccess>
          <Action ID="UseDefaultSetpoint"/>
        </ForceSuccess>
      </Fallback>

      <!-- Fault subsystem -->
      <Fallback name="fault_handler">
        <Sequence name="handle_sensor_fault">
          <Condition ID="IsSensorFaulty"/>
          <Action ID="LogFault"/>
          <Action ID="EnterSafeMode"/>
        </Sequence>
        <ForceSuccess>
          <Action ID="NoFaultDetected"/>
        </ForceSuccess>
      </Fallback>

    </Parallel>
  </BehaviorTree>
</root>
