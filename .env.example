# =============================================================================
# llm-bt-gen — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in only the providers you intend to use.
# Provider selection happens at runtime via:
#   - CLI / config:  model.provider in experiments/configs/*.yaml
#   - env override:  LLM_PROVIDER=...
#   - implicit:      inferred from model name (gpt-* → openai, claude-* → anthropic)
#
# You only need credentials for the providers you actually run.
# =============================================================================


# -----------------------------------------------------------------------------
# Common knobs
# -----------------------------------------------------------------------------
# Default temperature when not overridden by config.
OPENAI_TEMPERATURE=0.7
# Default max output tokens when not overridden by config.
OPENAI_MAX_TOKENS=4096
# Optional global seed (best-effort determinism). Leave unset for sampling.
# LLM_SEED=42


# -----------------------------------------------------------------------------
# Provider 1: OpenAI direct
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
# Default model used when config doesn't specify one.
OPENAI_MODEL=gpt-4


# -----------------------------------------------------------------------------
# Provider 2: Anthropic direct (Claude family)
# -----------------------------------------------------------------------------
# Requires `pip install anthropic`.
# Example models: claude-3-5-sonnet-latest, claude-3-opus-latest
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here


# -----------------------------------------------------------------------------
# Provider 3: OpenAI-compatible hosted services
# -----------------------------------------------------------------------------
# Use any of the well-known providers below by setting its env var; the
# client picks the first one available. Or use COMPATIBLE_API_KEY +
# COMPATIBLE_BASE_URL for an explicit override.
#
# To force a specific provider when several keys are set, use:
#   COMPATIBLE_PROVIDER=together   # or fireworks/groq/openrouter/mistral/deepseek
#
# Recommended for Llama-3 70B benchmark: Together AI ($0.88 / M tokens).

# Together AI — recommended (Llama-3 70B, Mixtral, Qwen, etc.)
# TOGETHER_API_KEY=...

# Fireworks
# FIREWORKS_API_KEY=...

# Groq (LPU, very fast)
# GROQ_API_KEY=...

# OpenRouter (one key, many models)
# OPENROUTER_API_KEY=...

# Mistral
# MISTRAL_API_KEY=...

# DeepSeek
# DEEPSEEK_API_KEY=...

# Custom OpenAI-compatible endpoint (overrides all of the above)
# COMPATIBLE_API_KEY=...
# COMPATIBLE_BASE_URL=https://your-server.example.com/v1


# -----------------------------------------------------------------------------
# Provider 4: Local model server (vLLM, llama.cpp server, LM Studio, Ollama)
# -----------------------------------------------------------------------------
# These all expose an OpenAI-compatible chat completions endpoint, so the same
# `compatible` backend handles them. The defaults below assume a server
# listening on http://localhost:8000/v1 — adjust to your setup.
#
# Examples:
#   vLLM:           python -m vllm.entrypoints.openai.api_server --model meta-llama/Meta-Llama-3-70B-Instruct
#   llama.cpp:      ./server -m model.gguf --host 0.0.0.0 --port 8000
#   LM Studio:      enable "Local Server" in the GUI (default port 1234) → set LOCAL_BASE_URL=http://localhost:1234/v1
#   Ollama:         ollama serve (default port 11434) → set LOCAL_BASE_URL=http://localhost:11434/v1
# Most local servers ignore the API key, so any non-empty string works.
# LOCAL_BASE_URL=http://localhost:8000/v1
# LOCAL_API_KEY=local
